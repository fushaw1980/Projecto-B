rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && isEmailVerified() && (request.auth.token.email == 'fushawshaw@gmail.com' || request.auth.token.email == 'wanderj419@gmail.com');
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             (data.get('fullName', null) == null || (data.fullName is string && data.fullName.size() <= 100)) &&
             data.email == request.auth.token.email &&
             data.role in ['client', 'worker', 'admin'] &&
             (data.get('category', null) == null || (data.category is string && data.category.size() <= 60)) &&
             (data.get('phone', null) == null || (data.phone is string && data.phone.size() <= 30)) &&
             (data.get('updatedAt', null) == null || data.updatedAt == request.time);
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.role == 'worker' || resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isOwner(userId) && isValidUser(incoming()) && (incoming().role != 'admin' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'role', 'category', 'bairro', 'phone', 'photo', 'level', 'jobs', 'verified', 'updatedAt']) &&
                    // Only Admin can verify or change roles to admin
                    (incoming().verified == existing().verified || isAdmin()) &&
                    (incoming().role == existing().role || incoming().role != 'admin' || isAdmin());
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
      }
    }

    // --- Job Validation ---
    function isValidJob(data) {
      return data.clientId == request.auth.uid &&
             data.category is string &&
             data.amount is number && data.amount > 0 &&
             data.status in ['AGUARDANDO_DEPOSITO', 'VALIDACAO_PENDENTE', 'PAGO', 'EM_CURSO', 'FINALIZADO', 'CONCLUIDO'] &&
             data.createdAt == request.time;
    }

    match /jobs/{jobId} {
      allow get: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.providerId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.providerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidJob(incoming());
      allow update: if isSignedIn() && (
        // Client actions
        (existing().clientId == request.auth.uid && (
          (incoming().status == 'VALIDACAO_PENDENTE' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'transactionId', 'updatedAt'])) ||
          (incoming().status == 'CONCLUIDO' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
        )) ||
        // Worker actions
        (existing().providerId == request.auth.uid && (
          (incoming().status == 'EM_CURSO' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'photoBefore', 'updatedAt'])) ||
          (incoming().status == 'FINALIZADO' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'photoAfter', 'updatedAt'])) ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['panicAlert', 'updatedAt']))
        )) ||
        // Admin actions
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
      ) && incoming().updatedAt == request.time;

      match /messages/{messageId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/jobs/$(jobId)).data.clientId == request.auth.uid || get(/databases/$(database)/documents/jobs/$(jobId)).data.providerId == request.auth.uid);
        allow create: if isSignedIn() && incoming().senderId == request.auth.uid && incoming().createdAt == request.time;
      }
    }
  }
}
